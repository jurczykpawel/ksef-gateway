# KSeF Authentication
KSEF_TOKEN=your-ksef-token-here
KSEF_NIP=0000000000
KSEF_ENV=TEST

# Multi-NIP license - only needed if you configure more than 1 NIP (contexts.json).
# A single NIP always works for free, no license needed. See README "Multi-NIP Licensing".
GATEWAY_LICENSE=

# API Port
KSEF_API_PORT=8080

# GitHub PAT for CIRFMF SDK (build-time only, needs read:packages)
GITHUB_PAT=ghp_your_token_here
