# KSeF Authentication - use a token (below) OR a certificate, not both.
# See README "Certificate-Based Auth" for the certificate option (KSEF_CERT_PATH/KSEF_KEY_PATH/KSEF_KEY_PASSWORD).
KSEF_TOKEN=your-ksef-token-here
KSEF_NIP=0000000000
KSEF_ENV=TEST

# API Port
KSEF_API_PORT=8080

# GitHub PAT for CIRFMF SDK (build-time only, needs read:packages)
GITHUB_PAT=ghp_your_token_here
