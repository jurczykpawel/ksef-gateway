# Gateway API key - REQUIRED for every request except GET /health (the gateway has no other
# caller-facing auth, so it fails closed without this). Generate one with: openssl rand -hex 32
# Send it back as the X-Api-Key header on every request. See README "Security".
GATEWAY_API_KEY=

# Optional: only accept traffic forwarded by a trusted proxy (Cloudflare, reverse proxy).
# When set, every request except GET /health must carry this secret in a header the proxy
# injects (default X-Trusted-Proxy-Secret, override with TRUSTED_PROXY_HEADER) - so a direct hit
# on the origin (e.g. *.onrender.com) that bypasses the proxy is rejected with 403. Leave blank
# to disable. Generate with: openssl rand -hex 32. See README "Security".
TRUSTED_PROXY_SECRET=
# TRUSTED_PROXY_HEADER=X-Trusted-Proxy-Secret

# KSeF Authentication - use a token (below) OR a certificate, not both.
# See README "Certificate-Based Auth" for the certificate option (KSEF_CERT_PATH/KSEF_KEY_PATH/KSEF_KEY_PASSWORD).
KSEF_TOKEN=your-ksef-token-here
KSEF_NIP=0000000000
KSEF_ENV=TEST

# Multi-NIP license - only needed if you configure more than 1 NIP (contexts.json).
# A single NIP always works for free, no license needed. See README "Multi-NIP Licensing".
GATEWAY_LICENSE=

# API Port
KSEF_API_PORT=8080

# GitHub PAT for CIRFMF SDK (build-time only, needs read:packages)
GITHUB_PAT=ghp_your_token_here
