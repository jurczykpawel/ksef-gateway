# Gateway API key - REQUIRED for every request except GET /health (the gateway has no other
# caller-facing auth, so it fails closed without this). Generate one with: openssl rand -hex 32
# Send it back as the X-Api-Key header on every request. See README "Security".
GATEWAY_API_KEY=

# KSeF Authentication - use a token (below) OR a certificate, not both.
# See README "Certificate-Based Auth" for the certificate option (KSEF_CERT_PATH/KSEF_KEY_PATH/KSEF_KEY_PASSWORD).
KSEF_TOKEN=your-ksef-token-here
KSEF_NIP=0000000000
KSEF_ENV=TEST

# API Port
KSEF_API_PORT=8080

# GitHub PAT for CIRFMF SDK (build-time only, needs read:packages)
GITHUB_PAT=ghp_your_token_here
