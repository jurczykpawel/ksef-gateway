---
const RENDER_URL = "https://render.com/deploy?repo=https://github.com/jurczykpawel/ksef-gateway";
const GITHUB_URL = "https://github.com/jurczykpawel/ksef-gateway";
const options = [
  { name: "Docker Compose", badge: "Lokalnie / VPS", badgeColor: "blue", desc: "Dwa polecenia i usługa działa. Bez konta w chmurze. Działa na każdym VPS.", code: `docker compose up --build`, link: { href: `${GITHUB_URL}#szybki-start`, label: "Dokumentacja" }, highlight: false },
  { name: "Render", badge: "Polecane", badgeColor: "accent", desc: "Wdrożenie jednym kliknięciem. Ustaw trzy zmienne środowiskowe. Darmowy tier. Oba kontenery (API + PDF) wdrażają się automatycznie.", code: `# Kliknij przycisk poniżej`, link: { href: RENDER_URL, label: "Wdróż na Render" }, highlight: true },
  { name: "AWS Lambda", badge: "Serverless", badgeColor: "yellow", desc: "Deploy jako Lambda z Function URL. SAM CLI obsługuje build. Bliskie zeru koszty przy małym ruchu.", code: `sam deploy --guided`, link: { href: `${GITHUB_URL}/tree/main/deploy/aws`, label: "Konfiguracja SAM" }, highlight: false },
  { name: "Azure Container Apps", badge: "Cloud", badgeColor: "blue", desc: "Zarządzane kontenery odzwierciedlające Docker Compose. Szablon Bicep w zestawie, zero zmian w kodzie.", code: `az deployment group create \\\n  --template-file deploy/azure/main.bicep`, link: { href: `${GITHUB_URL}/tree/main/deploy/azure`, label: "Szablon Bicep" }, highlight: false },
];
const badgeStyles = {
  accent: "bg-[var(--color-accent-soft)] text-[var(--color-accent-bright)] border-[var(--color-accent)]/20",
  blue: "bg-blue-500/10 text-blue-400 border-blue-500/20",
  yellow: "bg-yellow-500/10 text-yellow-400 border-yellow-500/20",
};
---
<section id="deploy" class="section-gap" aria-labelledby="deploy-heading">
  <div class="container-kg">
    <div class="section-label" data-dep>
      <svg width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true"><polyline points="2 9 6 3 10 9" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
      Wdrożenie
    </div>
    <h2 id="deploy-heading" class="text-3xl sm:text-4xl font-bold text-[var(--color-ink)] mb-3" data-dep>Wdróż wszędzie</h2>
    <p class="text-[var(--color-muted)] mb-12 max-w-lg" data-dep>Docker, serverless czy zarządzana chmura — wszystkie konfiguracje są w repozytorium.</p>
    <div class="grid sm:grid-cols-2 gap-5">
      {options.map((opt) => (
        <article class:list={["card-floating card-lift p-6 flex flex-col gap-5", opt.highlight ? "border-[var(--color-accent)]/30 bg-gradient-to-br from-indigo-500/5 to-transparent" : ""]} data-dep>
          <div class="flex items-start justify-between gap-3">
            <h3 class="text-base font-semibold text-[var(--color-ink)]">{opt.name}</h3>
            <span class:list={["text-xs font-medium px-2 py-0.5 rounded-full border", badgeStyles[opt.badgeColor]]}>{opt.badge}</span>
          </div>
          <p class="text-sm text-[var(--color-muted)] leading-relaxed flex-1">{opt.desc}</p>
          <div class="code-block">
            <div class="p-3.5 text-xs font-mono whitespace-pre text-[var(--color-muted)]">{opt.code}</div>
          </div>
          <a href={opt.link.href} target="_blank" rel="noopener noreferrer" class:list={["link-arrow inline-flex items-center gap-1.5 text-sm font-medium transition-colors", opt.highlight ? "text-[var(--color-accent-bright)] hover:text-[#a5b4fc]" : "text-[var(--color-muted)] hover:text-[var(--color-ink)]"]}>
            {opt.link.label}
            <svg width="13" height="13" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M3 8h10M9 4l4 4-4 4"/></svg>
          </a>
        </article>
      ))}
    </div>
    <div class="mt-8 card-floating p-5 flex flex-col sm:flex-row items-start sm:items-center gap-4" data-dep>
      <div class="flex-1">
        <p class="text-sm font-semibold text-[var(--color-ink)] mb-0.5">Postaw jedną komendą — na Mikrusie lub dowolnym VPS</p>
        <p class="text-sm text-[var(--color-muted)]">
          Klucz API i pozostałe sekrety generują się same. Nie masz serwera?
          <a href="https://mikr.us/?r=pavvel" target="_blank" rel="noopener noreferrer" class="text-[var(--color-accent-bright)] hover:underline">Mikrus</a>
          od ~5&nbsp;zł/mies. w zupełności wystarcza.
        </p>
      </div>
      <div class="code-block shrink-0">
        <div class="px-4 py-3 text-xs font-mono text-[var(--color-muted)]">curl&nbsp;-fsSL&nbsp;stackpilot.techskills.academy/ksef-gateway&nbsp;|&nbsp;bash</div>
      </div>
    </div>
  </div>
</section>
<script>
  import { reveal } from "../scripts/reveal";
  reveal("[data-dep]", { duration: 0.5, delayStep: 0.06, margin: "0px 0px -30px 0px", distance: 14 });
</script>
