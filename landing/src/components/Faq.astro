---
const items = [
  {
    q: "Czy muszę mieć podpis kwalifikowany?",
    a: "Nie. Do wygenerowania tokenu produkcyjnego wystarczy Profil Zaufany — darmowy, masz go zwykle z bankowości. Spółki dodatkowo składają jednorazowo formularz ZAW-FA w urzędzie skarbowym (chyba że mają pieczęć kwalifikowaną).",
  },
  {
    q: "Gdzie trzyma się mój token KSeF? Czy to bezpieczne?",
    a: "Wyłącznie na Twoim serwerze, w zmiennej środowiskowej. Gateway nie ma bazy danych ani zewnętrznego serwisu pośredniczącego — token nigdzie nie wypływa poza oficjalne API KSeF, do którego się nim uwierzytelnia.",
  },
  {
    q: "Czy ktokolwiek, kto znajdzie mój URL, może wysłać fakturę w moim imieniu?",
    a: "Nie — każde zapytanie (poza /health) wymaga nagłówka X-Api-Key z Twoim własnym kluczem gatewaya. Bez niego dostajesz 401, a jeśli klucz w ogóle nie jest ustawiony, gateway odrzuca wszystko (fail-closed), zamiast po cichu zostać otwarty.",
  },
  {
    q: "Ile to kosztuje?",
    a: "Sam gateway jest open source (AGPL-3.0) i darmowy. Płacisz jedynie za hosting — własny serwer, darmowy tier Render albo pay-as-you-go Lambda/Azure. Samo KSeF jest bezpłatne.",
  },
  {
    q: "Czy przejście z testu na produkcję wymaga zmian w kodzie?",
    a: "Nie. Podmieniasz KSEF_TOKEN, KSEF_NIP i ustawiasz KSEF_ENV=PRODUCTION w konfiguracji, restartujesz bramę. Endpointy, format JSON i cała reszta integracji zostają identyczne.",
  },
  {
    q: "Co się stanie, jeśli przekroczę limit zapytań KSeF?",
    a: "Gateway pilnuje oficjalnych limitów po swojej stronie i odda Ci 429 z nagłówkiem Retry-After, zanim jeszcze uderzy w limit KSeF — nie musisz sam implementować throttlingu.",
  },
  {
    q: "Obsługuję kilka firm/NIP-ów — da się to zrobić z jednej instancji?",
    a: "Tak, przez tryb multi-NIP: plik contexts.json z tokenem per firma, auto-routing po nagłówku X-KSeF-NIP albo NIP sprzedawcy z faktury.",
  },
];
---
<section id="faq" class="section-gap" aria-labelledby="faq-heading">
  <div class="container-kg">
    <div class="section-label" data-faq>
      <svg width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true">
        <circle cx="6" cy="6" r="5" stroke="currentColor" stroke-width="1.5"/>
        <path d="M4.3 4.5a1.7 1.7 0 0 1 3.3.5c0 1-1.3 1.1-1.3 2.1" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/>
        <circle cx="6" cy="8.7" r="0.55" fill="currentColor"/>
      </svg>
      Pytania
    </div>
    <h2 id="faq-heading" class="text-3xl sm:text-4xl font-bold text-[var(--color-ink)] mb-3" data-faq>Najczęstsze pytania</h2>
    <p class="text-[var(--color-muted)] mb-12 max-w-lg" data-faq>To, co zwykle pada w pierwszej rozmowie o wdrożeniu.</p>

    <div class="card-floating divide-y divide-[var(--color-line-strong)]" data-faq>
      {items.map((item) => (
        <details class="group p-5 sm:p-6">
          <summary class="flex items-center justify-between gap-4 cursor-pointer list-none text-sm sm:text-base font-semibold text-[var(--color-ink)]">
            {item.q}
            <svg class="shrink-0 transition-transform duration-200 group-open:rotate-45" width="18" height="18" viewBox="0 0 16 16" fill="none" stroke="var(--color-accent)" stroke-width="1.8" stroke-linecap="round" aria-hidden="true">
              <path d="M8 3v10M3 8h10"/>
            </svg>
          </summary>
          <p class="mt-3 text-sm text-[var(--color-muted)] leading-relaxed max-w-2xl">{item.a}</p>
        </details>
      ))}
    </div>
  </div>
</section>
<script>
  import { animate, inView } from "motion";
  document.querySelectorAll("[data-faq]").forEach((el, i) => {
    el.style.opacity = "0"; el.style.transform = "translateY(14px)";
    inView(el, () => { animate(el, { opacity: 1, transform: "translateY(0px)" }, { duration: 0.5, delay: i * 0.05, easing: [0.22, 1, 0.36, 1] }); }, { margin: "0px 0px -30px 0px" });
  });
</script>
