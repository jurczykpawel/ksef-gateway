---
const features = [
  { icon: `<path d="M13 10V3L4 14h7v7l9-11h-7z" stroke-linecap="round" stroke-linejoin="round"/>`, title: "Jedno wywołanie HTTP", desc: "Wyślij JSON, otrzymaj numer KSeF. Brama obsługuje XML FA(3), szyfrowanie AES-256, zarządzanie sesjami i odpytywanie statusu." },
  { icon: `<path d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" stroke-linecap="round" stroke-linejoin="round"/>`, title: "Przyjazny JSON", desc: "{sprzedawca, nabywca, pozycje} — z automatycznym obliczaniem VAT. Bez znajomości schematu FA(3) i polskich nazw pól." },
  { icon: `<path d="M7 21h10a2 2 0 002-2V9.414a1 1 0 00-.293-.707l-5.414-5.414A1 1 0 0012.586 3H7a2 2 0 00-2 2v14a2 2 0 002 2z" stroke-linecap="round" stroke-linejoin="round"/><path d="M10 12l2 2 4-4" stroke-linecap="round" stroke-linejoin="round"/>`, title: "PDF z kodem QR", desc: "Pobierz zweryfikowany PDF faktury po numerze KSeF. QR zawiera hash SHA-256 do weryfikacji. Oficjalna biblioteka CIRFMF." },
  { icon: `<path d="M9 3H5a2 2 0 00-2 2v4m6-6h10a2 2 0 012 2v4M9 3v18m0 0h10a2 2 0 002-2V9M9 21H5a2 2 0 01-2-2V9m0 0h18" stroke-linecap="round" stroke-linejoin="round"/>`, title: "Oficjalny SDK MF w środku", desc: "Opakowanie CIRFMF/ksef-client-csharp — SDK utrzymywanego przez Ministerstwo Finansów. Nie reverse-engineering strony trzeciej." },
  { icon: `<path d="M4 6h16M4 12h16M4 18h7" stroke-linecap="round" stroke-linejoin="round"/>`, title: "60+ endpointów auto-odkrywanych", desc: "Wszystkie metody IKSeFClient wystawione jako REST via refleksja .NET. Aktualizacje SDK propagują automatycznie przy przebudowie." },
  { icon: `<path d="M5 12H3m9-9V1M3.6 3.6L5 5m-.4 7H3m16.4-7L18 5m1.4 7H18m-7 4.4V18m-7.4 1.4L5 18m9 1.4L13 18" stroke-linecap="round" stroke-linejoin="round"/><circle cx="12" cy="12" r="4" stroke-linecap="round"/>`, title: "Wdróż wszędzie", desc: "Docker Compose, Render jednym kliknięciem, AWS Lambda (SAM), Azure Container Apps (Bicep). Wszystkie konfiguracje w repo." },
];
---
<section id="features" class="section-gap" aria-labelledby="features-heading">
  <div class="container-kg">
    <div class="section-label" data-fin>
      <svg width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true"><path d="M1 6h10M7 2l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
      Funkcje
    </div>
    <h2 id="features-heading" class="text-3xl sm:text-4xl font-bold text-[var(--color-ink)] mb-3" data-fin>Wszystko obsłużone za Ciebie</h2>
    <p class="text-[var(--color-muted)] mb-12 max-w-lg" data-fin>KSeF Gateway to cienka, przezroczysta warstwa — cała złożoność KSeF jest w środku, a Twój kod widzi tylko HTTP.</p>
    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
      {features.map((f, i) => (
        <article class="card-floating p-6 flex flex-col gap-4 hover:border-[var(--color-line-bright)] transition-colors" data-fin style={`transition-delay: ${i * 40}ms`}>
          <div class="w-10 h-10 flex items-center justify-center rounded-xl bg-[var(--color-accent-soft)] border border-[var(--color-accent)]/15 shrink-0">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--color-accent)" stroke-width="1.8" aria-hidden="true" set:html={f.icon} />
          </div>
          <div>
            <h3 class="text-sm font-semibold text-[var(--color-ink)] mb-1.5">{f.title}</h3>
            <p class="text-sm text-[var(--color-muted)] leading-relaxed">{f.desc}</p>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>
<script>
  import { animate, inView } from "motion";
  document.querySelectorAll("[data-fin]").forEach((el, i) => {
    el.style.opacity = "0"; el.style.transform = "translateY(14px)";
    inView(el, () => { animate(el, { opacity: 1, transform: "translateY(0px)" }, { duration: 0.5, delay: i * 0.05, easing: [0.22, 1, 0.36, 1] }); }, { margin: "0px 0px -30px 0px" });
  });
</script>
