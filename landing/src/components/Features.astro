---
const features = [
  { icon: `<path d="M13 10V3L4 14h7v7l9-11h-7z" stroke-linecap="round" stroke-linejoin="round"/>`, title: "Faktura w systemie jednym żądaniem", desc: "Wysyłasz dane faktury, dostajesz z powrotem numer KSeF. Wszystko pomiędzy — formaty, szyfrowanie, sesje, statusy — dzieje się bez Twojego udziału." },
  { icon: `<path d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" stroke-linecap="round" stroke-linejoin="round"/>`, title: "Piszesz po ludzku, nie po urzędowemu", desc: "Sprzedawca, nabywca, pozycje — tyle wystarczy. VAT liczy się sam. Nie musisz znać schematu faktury ani pól typu P_13_1." },
  { icon: `<path d="M7 21h10a2 2 0 002-2V9.414a1 1 0 00-.293-.707l-5.414-5.414A1 1 0 0012.586 3H7a2 2 0 00-2 2v14a2 2 0 002 2z" stroke-linecap="round" stroke-linejoin="round"/><path d="M10 12l2 2 4-4" stroke-linecap="round" stroke-linejoin="round"/>`, title: "PDF gotowy do wysłania klientowi", desc: "Jedno żądanie i masz PDF faktury z kodem QR, który każdy może zweryfikować w KSeF. Generowany oficjalną biblioteką Ministerstwa." },
  { icon: `<path d="M3 8l9 6 9-6M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" stroke-linecap="round" stroke-linejoin="round"/>`, title: "Wiesz, gdy ktoś wystawi Ci fakturę", desc: "KSeF nie wysyła powiadomień — brama tak. Cykliczne sprawdzanie nowych faktur, gotowe do podpięcia pod maila, Slacka albo n8n." },
  { icon: `<path d="M9 3H5a2 2 0 00-2 2v4m6-6h10a2 2 0 012 2v4M9 3v18m0 0h10a2 2 0 002-2V9M9 21H5a2 2 0 01-2-2V9m0 0h18" stroke-linecap="round" stroke-linejoin="round"/>`, title: "Oficjalne fundamenty, nie zgadywanie", desc: "W środku pracuje SDK utrzymywane przez Ministerstwo Finansów. Gdy KSeF się zmienia, zmiany przychodzą oficjalnym kanałem — nie odwrotną inżynierią." },
  { icon: `<path d="M4 6h16M4 12h16M4 18h7" stroke-linecap="round" stroke-linejoin="round"/>`, title: "Niczego Ci nie zabraknie", desc: "Poza prostymi operacjami masz dostęp do pełnego API KSeF — ponad 60 operacji, od wysyłki wsadowej po zarządzanie uprawnieniami. Na zapas." },
  { icon: `<path d="M5 12H3m9-9V1M3.6 3.6L5 5m-.4 7H3m16.4-7L18 5m1.4 7H18m-7 4.4V18m-7.4 1.4L5 18m9 1.4L13 18" stroke-linecap="round" stroke-linejoin="round"/><circle cx="12" cy="12" r="4" stroke-linecap="round"/>`, title: "Postawisz tam, gdzie Ci wygodnie", desc: "Własny serwer, darmowy hosting w chmurze, AWS albo Azure — gotowe konfiguracje na każdą opcję. Bez uzależnienia od jednego dostawcy." },
];
---
<section id="features" class="section-gap" aria-labelledby="features-heading">
  <div class="container-kg">
    <div class="section-label" data-fin>
      <svg width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true"><path d="M1 6h10M7 2l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
      Funkcje
    </div>
    <h2 id="features-heading" class="text-3xl sm:text-4xl font-bold text-[var(--color-ink)] mb-3" data-fin>Wszystko obsłużone za Ciebie</h2>
    <p class="text-[var(--color-muted)] mb-12 max-w-lg" data-fin>Cała złożoność KSeF zostaje w środku bramy. Ty widzisz proste, przewidywalne API — i wyniki.</p>
    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
      {features.map((f, i) => (
        <article class="card-floating card-lift p-6 flex flex-col gap-4" data-fin>
          <div class="w-10 h-10 flex items-center justify-center rounded-xl bg-[var(--color-accent-soft)] border border-[var(--color-accent)]/15 shrink-0">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--color-accent)" stroke-width="1.8" aria-hidden="true" set:html={f.icon} />
          </div>
          <div>
            <h3 class="text-sm font-semibold text-[var(--color-ink)] mb-1.5">{f.title}</h3>
            <p class="text-sm text-[var(--color-muted)] leading-relaxed">{f.desc}</p>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>
<script>
  import { reveal } from "../scripts/reveal";
  reveal("[data-fin]", { duration: 0.5, delayStep: 0.05, margin: "0px 0px -30px 0px", distance: 14 });
</script>
