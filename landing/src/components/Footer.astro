---
const GITHUB_URL = "https://github.com/jurczykpawel/ksef-gateway";
const year = new Date().getFullYear();
---
<footer class="border-t border-[var(--color-line-strong)] py-10">
  <div class="container-kg flex flex-col sm:flex-row items-center justify-between gap-4">
    <div class="flex items-center gap-2.5 text-sm font-semibold text-[var(--color-muted)]">
      <svg width="18" height="18" viewBox="0 0 22 22" fill="none" aria-hidden="true">
        <rect x="2" y="2" width="18" height="18" rx="4" fill="var(--color-accent)" fill-opacity="0.1" stroke="var(--color-accent)" stroke-width="1.5"/>
        <path d="M6 7.5h10M6 11h10M6 14.5h6" stroke="var(--color-accent)" stroke-width="1.5" stroke-linecap="round"/>
      </svg>
      KSeF Gateway
    </div>
    <nav class="flex items-center gap-5 text-xs text-[var(--color-faint)]" aria-label="Stopka">
      <a href={`${GITHUB_URL}#readme`} target="_blank" rel="noopener noreferrer" class="hover:text-[var(--color-muted)] transition-colors">Dokumentacja</a>
      <a href={`${GITHUB_URL}/blob/main/CHANGELOG.md`} target="_blank" rel="noopener noreferrer" class="hover:text-[var(--color-muted)] transition-colors">Changelog</a>
      <a href={`${GITHUB_URL}/blob/main/LICENSE`} target="_blank" rel="noopener noreferrer" class="hover:text-[var(--color-muted)] transition-colors">AGPL-3.0</a>
      <a href={GITHUB_URL} target="_blank" rel="noopener noreferrer" class="hover:text-[var(--color-muted)] transition-colors">GitHub</a>
    </nav>
    <p class="text-xs text-[var(--color-faint)]">&copy; {year} Pawel Jurczyk</p>
  </div>
</footer>
