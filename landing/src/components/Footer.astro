---
const GITHUB_URL = "https://github.com/jurczykpawel/ksef-gateway";
const year = new Date().getFullYear();

const cols = [
  {
    h: "KSeF Gateway",
    links: [
      ["Funkcje", "#features"],
      ["Jak to działa", "#how-it-works"],
      ["Wdrożenie", "#deploy"],
      ["Integracje", "#integrations"],
    ],
  },
  {
    h: "Projekt",
    links: [
      ["Dokumentacja", `${GITHUB_URL}#readme`],
      ["Changelog", `${GITHUB_URL}/blob/main/CHANGELOG.md`],
      ["Licencja AGPL-3.0", `${GITHUB_URL}/blob/main/LICENSE`],
      ["GitHub", GITHUB_URL],
    ],
  },
  {
    h: "Ekosystem TSA",
    links: [
      ["Wszystkie narzędzia", "https://techskills.academy/narzedzia"],
      ["ReelStack", "https://reelstack.techskills.academy"],
      ["Captions CLI", "https://captions.techskills.academy"],
      ["Stackpilot", "https://stackpilot.techskills.academy"],
    ],
  },
  {
    h: "Twórca",
    links: [
      ["Pawel Jurczyk", "https://me.techskills.academy"],
      ["TechSkills Academy", "https://techskills.academy"],
      ["LinkedIn", "https://linkedin.com/in/jurczykpawel"],
    ],
  },
];
---
<footer class="border-t border-[var(--color-line-strong)] mt-8">
  <div class="container-kg py-14 grid gap-10 sm:grid-cols-2 lg:grid-cols-[1.4fr_repeat(3,1fr)]">
    <div>
      <div class="flex items-center gap-2.5 mb-4">
        <svg width="20" height="20" viewBox="0 0 22 22" fill="none" aria-hidden="true">
          <rect x="2" y="2" width="18" height="18" rx="4" fill="var(--color-accent)" fill-opacity="0.12" stroke="var(--color-accent)" stroke-width="1.5"/>
          <path d="M6 7.5h10M6 11h10M6 14.5h6" stroke="var(--color-accent)" stroke-width="1.5" stroke-linecap="round"/>
        </svg>
        <span class="font-semibold text-[var(--color-ink)]">KSeF Gateway</span>
      </div>
      <p class="text-sm text-[var(--color-muted)] leading-relaxed max-w-[26ch]">
        Brama REST API do KSeF. Wyślij JSON, otrzymaj numer KSeF.
      </p>
    </div>

    {cols.map((col) => (
      <nav aria-label={col.h}>
        <h2 class="text-xs font-semibold uppercase tracking-widest text-[var(--color-faint)] mb-3">{col.h}</h2>
        <ul class="space-y-2">
          {col.links.map(([label, href]) => (
            <li>
              <a
                href={href}
                class="text-sm text-[var(--color-muted)] hover:text-[var(--color-ink)] transition-colors"
                {...(href.startsWith("http") ? { target: "_blank", rel: "noopener noreferrer" } : {})}
              >{label}</a>
            </li>
          ))}
        </ul>
      </nav>
    ))}
  </div>

  <div class="container-kg py-5 border-t border-[var(--color-line)] text-xs text-[var(--color-faint)] flex flex-col sm:flex-row gap-2 justify-between">
    <span>&copy; {year} Pawel Jurczyk &middot; Open source &middot; AGPL-3.0</span>
    <span>Narzędzie TechSkills Academy</span>
  </div>
</footer>
