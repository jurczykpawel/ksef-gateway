---
const GITHUB_URL = "https://github.com/jurczykpawel/ksef-gateway";
const RENDER_URL = "https://render.com/deploy?repo=https://github.com/jurczykpawel/ksef-gateway";
---
<section class="section-gap pt-20 md:pt-28 overflow-hidden" aria-label="Hero">
  <div class="container-kg">
    <div class="flex flex-col lg:flex-row items-start lg:items-center gap-14 lg:gap-10">

      <div class="flex-1 min-w-0">
        <div class="section-label" data-reveal>
          <svg width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true">
            <circle cx="6" cy="6" r="5" stroke="currentColor" stroke-width="1.5"/>
            <circle cx="6" cy="6" r="2" fill="currentColor"/>
          </svg>
          Open Source · AGPL-3.0 · Oficjalny SDK MF
        </div>

        <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold leading-[1.08] tracking-tight text-[var(--color-ink)] mb-5" data-reveal>
          Jedno wywołanie HTTP.<br/>
          Jeden numer KSeF.
        </h1>

        <p class="text-lg text-[var(--color-muted)] leading-relaxed max-w-xl mb-8" data-reveal>
          KSeF Gateway opakowuje oficjalny SDK e-Faktur Ministerstwa Finansów.
          Wysyłasz JSON ze sprzedawcą, nabywcą i pozycjami &mdash; otrzymujesz numer KSeF.
          Bez XML FA(3), bez szyfrowania AES-256, bez zarządzania sesjami.
        </p>

        <div class="flex flex-wrap items-center gap-3" data-reveal>
          <a href={RENDER_URL} target="_blank" rel="noopener noreferrer" class="btn-primary">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <polyline points="16 16 12 12 8 16"/>
              <line x1="12" y1="12" x2="12" y2="21"/>
              <path d="M20.39 18.39A5 5 0 0 0 18 9h-1.26A8 8 0 1 0 3 16.3"/>
            </svg>
            Wdróż na Render
          </a>
          <a href={GITHUB_URL} target="_blank" rel="noopener noreferrer" class="btn-ghost">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M12 .5A11.5 11.5 0 0 0 .5 12a11.5 11.5 0 0 0 7.86 10.92c.57.1.78-.25.78-.55v-2c-3.2.7-3.88-1.37-3.88-1.37-.52-1.33-1.28-1.69-1.28-1.69-1.05-.71.08-.7.08-.7 1.16.08 1.77 1.19 1.77 1.19 1.03 1.76 2.7 1.25 3.36.96.1-.75.4-1.26.73-1.55-2.56-.29-5.26-1.28-5.26-5.7 0-1.26.45-2.29 1.19-3.1-.12-.29-.52-1.46.11-3.05 0 0 .97-.31 3.18 1.18a11 11 0 0 1 5.78 0c2.2-1.49 3.17-1.18 3.17-1.18.63 1.59.23 2.76.11 3.05.74.81 1.19 1.84 1.19 3.1 0 4.43-2.7 5.4-5.28 5.69.41.36.78 1.06.78 2.14v3.17c0 .31.21.66.79.55A11.5 11.5 0 0 0 23.5 12 11.5 11.5 0 0 0 12 .5Z"/>
            </svg>
            GitHub
          </a>
        </div>

        <div class="flex flex-wrap items-center gap-x-5 gap-y-2 mt-8 text-xs text-[var(--color-faint)]" data-reveal>
          {[".NET 9 w Dockerze", "Bez lokalnego .NET", "81 testów przechodzi", "Darmowy tier na Render"].map(t => (
            <span class="flex items-center gap-1.5">
              <svg width="12" height="12" viewBox="0 0 16 16" fill="var(--color-accent)" aria-hidden="true">
                <path d="M8 .5a7.5 7.5 0 1 0 0 15A7.5 7.5 0 0 0 8 .5Zm3.28 5.72-4 4a.75.75 0 0 1-1.06 0l-2-2a.75.75 0 0 1 1.06-1.06L6.75 8.69l3.47-3.47a.75.75 0 1 1 1.06 1.06Z"/>
              </svg>
              {t}
            </span>
          ))}
        </div>
      </div>

      <div class="w-full lg:w-[520px] shrink-0" data-reveal>
        <div class="code-block shadow-2xl shadow-black/50">
          <div class="terminal-bar">
            <span class="terminal-dot bg-[#ff5f56]"></span>
            <span class="terminal-dot bg-[#ffbd2e]"></span>
            <span class="terminal-dot bg-[#27c93f]"></span>
            <span class="ml-2 text-xs text-[var(--color-faint)]">faktura.sh</span>
          </div>
          <div class="p-5 text-sm font-mono" id="hero-request"></div>
          <div class="border-t border-[var(--color-line-strong)] px-5 py-4">
            <div class="text-xs text-[var(--color-faint)] mb-2">Odpowiedź</div>
            <div class="text-sm font-mono" id="hero-response"></div>
          </div>
        </div>
        <div class="mt-4 flex items-center gap-2 text-xs text-[var(--color-faint)]">
          <svg width="12" height="12" viewBox="0 0 16 16" fill="var(--color-accent)" aria-hidden="true">
            <path d="M8 .5a7.5 7.5 0 1 0 0 15A7.5 7.5 0 0 0 8 .5Zm3.28 5.72-4 4a.75.75 0 0 1-1.06 0l-2-2a.75.75 0 0 1 1.06-1.06L6.75 8.69l3.47-3.47a.75.75 0 1 1 1.06 1.06Z"/>
          </svg>
          Brama obsługuje XML FA(3) &middot; szyfrowanie AES-256 &middot; sesje KSeF &middot; auto-refresh
        </div>
      </div>

    </div>
  </div>
</section>

<script>
  import { animate, inView } from "motion";

  function hl(text, cls) { return `<span class="${cls}">${text}</span>`; }
  const k = t => hl(t, "text-[#93c5fd]");
  const v = t => hl(t, "text-[#fbbf24]");
  const m = t => hl(t, "text-[var(--color-muted)]");
  const c = t => hl(t, "text-[var(--color-blue)]");
  const a = t => hl(t, "text-[var(--color-accent-bright)]");

  const req = document.getElementById("hero-request");
  if (req) {
    req.innerHTML = [
      `<div class="text-[var(--color-faint)] select-none mb-1">$</div>`,
      `<div>${c("curl")} ${m("-X POST https://twoja-brama/ksef/invoice \\")}</div>`,
      `<div class="pl-4">${m("-H ")}${v('"Content-Type: application/json"')} ${m("\\")}</div>`,
      `<div class="pl-4">${m("-d '")}${m("{")}${k('"sprzedawca"')}${m(":")}${m("{")}${k('"nip"')}${m(":")}${v('"1234567890"')}${m("...}")}${m(",")}</div>`,
      `<div class="pl-8">${k('"nabywca"')}${m(":")}${m("{")}${k('"nip"')}${m(":")}${v('"0987654321"')}${m("...}")}${m(",")}</div>`,
      `<div class="pl-8">${k('"pozycje"')}${m(": [")}${m("{")}${k('"nazwa"')}${m(":")}${v('"Usługa"')}${m(",")}${k('"cenaNetto"')}${m(":")}${a("150")}${m("...}]'")}</div>`,
    ].join("\n");
  }

  const res = document.getElementById("hero-response");
  if (res) {
    res.innerHTML = [
      `<div>${m("{")}</div>`,
      `<div class="pl-4">${k('"sukces"')}${m(": ")}${a("true")}${m(",")}</div>`,
      `<div class="pl-4">${k('"dane"')}${m(": {")}`,
      `<div class="pl-8">${k('"numerKSeF"')}${m(": ")}${v('"1234567890-20260326-5EC118-05"')}</div>`,
      `<div class="pl-4">${m("}")}</div>`,
      `<div>${m("}")}</div>`,
    ].join("\n");
  }

  document.querySelectorAll("[data-reveal]").forEach((el, i) => {
    el.style.opacity = "0";
    el.style.transform = "translateY(18px)";
    inView(el, () => {
      animate(el, { opacity: 1, transform: "translateY(0px)" }, {
        duration: 0.55, delay: i * 0.07, easing: [0.22, 1, 0.36, 1],
      });
    }, { margin: "0px 0px -60px 0px" });
  });
</script>
