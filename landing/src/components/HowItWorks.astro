---
const steps = [
  { n: "01", title: "Uruchom bramę", desc: "Jedno polecenie na dowolnym komputerze z Dockerem — niczego więcej nie instalujesz.", code: `docker compose up --build\n# API gotowe na http://localhost:8080`, or: 'Wolisz bez terminala? Kliknij „Wdróż na Render" — brama stawia się sama w chmurze.' },
  { n: "02", title: "Zdobądź certyfikat KSeF", desc: "Do testów: jedno polecenie i masz gotowy certyfikat na środowisku testowym KSeF. Na produkcji: logujesz się Profilem Zaufanym (masz go z bankowości, za darmo) na ap.ksef.mf.gov.pl i wyklikujesz certyfikat w kilka chwil — bez podpisu kwalifikowanego.", code: `docker compose --profile tools run \\\n  --rm cert-generator\n# zapisuje certyfikat, klucz i NIP do ./output`, or: null },
  { n: "03", title: "Wyślij pierwszą fakturę", desc: "Dane sprzedawcy, nabywcy i pozycje — w odpowiedzi dostajesz numer KSeF. Twoja pierwsza faktura właśnie jest w systemie.", code: `curl -X POST http://localhost:8080/ksef/invoice \\\n  -d '{"sprzedawca":{...},"nabywca":{...},"pozycje":[...]}'\n# → {"numerKSeF":"1234567890-20260326-..."}`, or: null },
];
---
<section id="how-it-works" class="section-gap" aria-labelledby="how-heading">
  <div class="container-kg">
    <div class="section-label" data-hiw>
      <svg width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true"><circle cx="6" cy="6" r="5" stroke="currentColor" stroke-width="1.5"/><path d="M4.5 6l1.5 1.5L7.5 4.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
      Szybki start
    </div>
    <h2 id="how-heading" class="text-3xl sm:text-4xl font-bold text-[var(--color-ink)] mb-3" data-hiw>Gotowy w trzech krokach</h2>
    <p class="text-[var(--color-muted)] mb-14 max-w-lg" data-hiw>Od zera do działającej integracji z KSeF w mniej niż pięć minut.</p>
    <div class="relative flex flex-col gap-8">
      <div class="hiw-line hidden md:block" data-hiw-line aria-hidden="true"></div>
      {steps.map((step) => (
        <div class="flex flex-col md:flex-row gap-6 md:gap-10 items-start" data-hiw>
          <div class="relative z-10 shrink-0 flex items-center justify-center w-12 h-12 rounded-xl bg-[var(--color-elevated)] border border-[var(--color-accent)]/20">
            <span class="text-sm font-bold font-mono text-[var(--color-accent-bright)]">{step.n}</span>
          </div>
          <div class="flex-1 min-w-0">
            <h3 class="text-lg font-semibold text-[var(--color-ink)] mb-1.5">{step.title}</h3>
            <p class="text-sm text-[var(--color-muted)] mb-4 leading-relaxed">
              {step.desc}
              {step.or && <span class="text-[var(--color-faint)]"> {step.or}</span>}
            </p>
            <div class="code-block">
              <div class="p-4 text-xs font-mono whitespace-pre text-[var(--color-muted)]">{step.code}</div>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
<script>
  import { inView } from "motion";
  import { reveal } from "../scripts/reveal";

  reveal("[data-hiw]", { duration: 0.5, delayStep: 0.07, margin: "0px 0px -40px 0px", distance: 14 });

  // Linia postępu rysuje się, gdy sekcja wchodzi w viewport (CSS transition robi resztę;
  // przy prefers-reduced-motion CSS pokazuje ją od razu w pełnej długości)
  const line = document.querySelector("[data-hiw-line]");
  if (line) {
    inView(line, () => line.classList.add("drawn"), { margin: "0px 0px -35% 0px" });
  }
</script>
