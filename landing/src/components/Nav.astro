---
const GITHUB_URL = "https://github.com/jurczykpawel/ksef-gateway";
const RENDER_URL = "https://render.com/deploy?repo=https://github.com/jurczykpawel/ksef-gateway";
---
<header id="nav" class="fixed top-0 inset-x-0 z-50 transition-[background,border-color] duration-300" data-nav>
  <div class="container-kg flex items-center justify-between" style="height: var(--nav-h)">
    <a href="/" class="flex items-center gap-2.5 text-sm font-semibold text-[var(--color-ink)] no-underline hover:opacity-80 transition-opacity">
      <svg width="22" height="22" viewBox="0 0 22 22" fill="none" aria-hidden="true">
        <rect x="2" y="2" width="18" height="18" rx="4" fill="var(--color-accent)" fill-opacity="0.15" stroke="var(--color-accent)" stroke-width="1.5"/>
        <path d="M6 7.5h10M6 11h10M6 14.5h6" stroke="var(--color-accent)" stroke-width="1.5" stroke-linecap="round"/>
      </svg>
      KSeF Gateway
    </a>

    <nav class="hidden md:flex items-center gap-0.5" aria-label="Główna">
      <a href="#features" class="px-3 py-2 text-sm text-[var(--color-muted)] hover:text-[var(--color-ink)] rounded-lg transition-colors">Funkcje</a>
      <a href="#how-it-works" class="px-3 py-2 text-sm text-[var(--color-muted)] hover:text-[var(--color-ink)] rounded-lg transition-colors">Jak to działa</a>
      <a href="#deploy" class="px-3 py-2 text-sm text-[var(--color-muted)] hover:text-[var(--color-ink)] rounded-lg transition-colors">Wdrożenie</a>
    </nav>

    <div class="flex items-center gap-2">
      <a
        href={GITHUB_URL}
        target="_blank"
        rel="noopener noreferrer"
        class="hidden sm:inline-flex items-center justify-center w-9 h-9 text-[var(--color-muted)] hover:text-[var(--color-ink)] rounded-lg border border-[var(--color-line-strong)] hover:border-[var(--color-line-bright)] transition-colors"
        aria-label="Repozytorium GitHub"
      >
        <svg width="17" height="17" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M12 .5A11.5 11.5 0 0 0 .5 12a11.5 11.5 0 0 0 7.86 10.92c.57.1.78-.25.78-.55v-2c-3.2.7-3.88-1.37-3.88-1.37-.52-1.33-1.28-1.69-1.28-1.69-1.05-.71.08-.7.08-.7 1.16.08 1.77 1.19 1.77 1.19 1.03 1.76 2.7 1.25 3.36.96.1-.75.4-1.26.73-1.55-2.56-.29-5.26-1.28-5.26-5.7 0-1.26.45-2.29 1.19-3.1-.12-.29-.52-1.46.11-3.05 0 0 .97-.31 3.18 1.18a11 11 0 0 1 5.78 0c2.2-1.49 3.17-1.18 3.17-1.18.63 1.59.23 2.76.11 3.05.74.81 1.19 1.84 1.19 3.1 0 4.43-2.7 5.4-5.28 5.69.41.36.78 1.06.78 2.14v3.17c0 .31.21.66.79.55A11.5 11.5 0 0 0 23.5 12 11.5 11.5 0 0 0 12 .5Z"/>
        </svg>
      </a>
      <a href={RENDER_URL} target="_blank" rel="noopener noreferrer" class="btn-primary text-sm">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <polyline points="16 16 12 12 8 16"/><line x1="12" y1="12" x2="12" y2="21"/>
          <path d="M20.39 18.39A5 5 0 0 0 18 9h-1.26A8 8 0 1 0 3 16.3"/>
        </svg>
        Wdróż
      </a>
    </div>
  </div>
</header>

<style>
  [data-nav] { border-bottom: 1px solid transparent; }
  [data-nav].scrolled {
    background: color-mix(in oklab, var(--color-base) 78%, transparent);
    backdrop-filter: saturate(1.6) blur(18px);
    -webkit-backdrop-filter: saturate(1.6) blur(18px);
    border-bottom-color: var(--color-line-strong);
  }
</style>

<script>
  const nav = document.querySelector("[data-nav]");
  const onScroll = () => nav?.classList.toggle("scrolled", window.scrollY > 10);
  onScroll();
  window.addEventListener("scroll", onScroll, { passive: true });
</script>
