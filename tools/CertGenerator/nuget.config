<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
    <add key="github-cirfmf" value="https://nuget.pkg.github.com/CIRFMF/index.json" />
  </packageSources>
  <packageSourceCredentials>
    <github-cirfmf>
      <add key="Username" value="token" />
      <add key="ClearTextPassword" value="%GITHUB_PAT%" />
    </github-cirfmf>
  </packageSourceCredentials>
</configuration>
